# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shunshousong?schema=public"

# JWT 配置
JWT_SECRET="shunshousong-secret-key-change-in-production"
JWT_EXPIRATION="7d"

# 服务器配置
PORT=3000
NODE_ENV="development"

# Redis 配置
REDIS_HOST="localhost"
REDIS_PORT=6379

# 高德地图 API（需要申请）
AMAP_API_KEY="your-amap-api-key"

# 短信服务配置（可选）
SMS_PROVIDER="aliyun"
SMS_ACCESS_KEY="your-access-key"
SMS_ACCESS_SECRET="your-access-secret"
SMS_SIGN_NAME="顺手送"

# 支付宝配置
ALIPAY_APP_ID="your-alipay-app-id"
ALIPAY_PRIVATE_KEY="your-alipay-private-key"
ALIPAY_PUBLIC_KEY="your-alipay-public-key"

# 微信支付配置
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_MCH_ID="your-wechat-mch-id"
WECHAT_API_KEY="your-wechat-api-key"
WECHAT_PRIVATE_KEY="your-wechat-private-key"
